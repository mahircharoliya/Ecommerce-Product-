# ─────────────────────────────────────────────
# Product Explorer — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────

# ── API ──────────────────────────────────────
VITE_API_BASE_URL=https://dummyjson.com
VITE_PRODUCTS_ENDPOINT=/products
VITE_PRODUCTS_LIMIT=100

# ── Razorpay ──────────────────────────────────
# Get your key from https://dashboard.razorpay.com → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_test_YourKeyHere

# ── App ───────────────────────────────────────
VITE_APP_NAME=Product Explorer
VITE_PAGE_SIZE=10
VITE_DEBOUNCE_DELAY=300
